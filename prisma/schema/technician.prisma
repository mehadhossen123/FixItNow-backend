model Technician {
  id         String  @id @default(uuid())
  userId     String  @unique
  bio        String?
  experience Int     @default(0)
  location   String
  slots      String[] @default([])

  // relation 
  user     User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  services Services[]
  bookings Booking[]
  review Review[]

  @@map("technician")
}
